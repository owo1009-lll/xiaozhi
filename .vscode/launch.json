    {
      "name": "Open Production App In Browser",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "cmd",
      "runtimeArgs": [
        "/c",
        "start",
        "http://127.0.0.1:3000"
      ],
      "preLaunchTask": "Start Production Server",
      "console": "integratedTerminal"
    }
  ]
}
