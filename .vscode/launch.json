{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Open Vite App In Browser",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "cmd",
      "runtimeArgs": [
        "/c",
        "start",
        "http://127.0.0.1:5173"
      ],
      "preLaunchTask": "Start Vite Dev Server",
