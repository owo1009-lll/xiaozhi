{
  "name": "music-theory-ai-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server": "node server.js",
    "build": "vite build",
    "start": "node server.js",
    "build:lesson-video": "node scripts/build-lesson-videos.cjs",
    "build:lesson-videos": "node scripts/build-lesson-videos.cjs --all",
    "build:experiment-sim": "node scripts/build-experiment-sim-package.mjs",
    "build:experiment-sim:v2": "node scripts/build-experiment-sim-package-v2.mjs",
    "build:mte": "node scripts/build-mte-package.mjs && node scripts/export-mte-word-docs.mjs",
    "build:mte:word": "node scripts/export-mte-word-docs.mjs",
    "test:ai-tutor": "node scripts/run-ai-tutor-regression.mjs",
    "test:composite-students": "node scripts/run-composite-student-simulation.mjs",
    "test:platform-deep": "node scripts/run-platform-deep-validation.mjs"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "openai": "^5.20.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "docx": "^9.6.1",
    "ffmpeg-static": "^5.3.0",
    "jstat": "^1.9.6",
    "ml-matrix": "^6.12.2",
    "playwright": "^1.59.1",
    "vercel": "^50.42.0",
    "vite": "^7.1.7",
    "xlsx": "^0.18.5"
  }
